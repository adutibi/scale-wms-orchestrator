# SQL Server (worker-service + scripts)
# Copy to .env and adjust: cp .env.example .env

DB_SERVER=192.168.123.242
DB_PORT=1433
# DB_INSTANCE=SQL2022DEV
DB_NAME=ils
DB_USER=manh
DB_PASSWORD=manh

DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MAX=20
DB_REQUEST_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=15000

# Worker throughput (docker-compose can override)
WORKER_PREFETCH=20

# Bearer token validation (orchestrator).
# Comma-separated list of allowed Azure AD application IDs (appid claim).
# Leave empty/unset to disable validation (e.g. local dev).
AUTH_APP_ID=fc066af7-9670-4f73-a16d-7fb2698f3292

# Observability (logging-service is the hub; all default to enabled)
AUDIT_LOG_ENABLED=true
METRICS_ENABLED=true
QUEUE_MONITOR_ENABLED=true
QUEUE_DEPTH_WARN_THRESHOLD=100
